# sites/web_user.env — example answers for one virtual host.
# Source this to run harden-vhost.sh / tune-vhost.sh non-interactively:
#     set -a; . sites/web_user.env; set +a; ./scripts/harden-vhost.sh
# Every value here matches a prompt in harden-vhost.sh; missing ones are asked.
#
# Two DISTINCT identities (do not confuse them):
#   RUNTIME_USER = web_user   -> the per-site PHP-FPM user (where the risk is)
#   WEB_USER     = www-data   -> owns the code / nginx + FTP identity; the
#                                runtime user reaches the code via THIS group.
# "web_user" here is just the example site username — rename it per site.

SITE=web_user
SERVER_NAME=web_user.example
DOCROOT=/var/www/html/web_user/public_html
RUNTIME_USER=web_user
WEB_USER=www-data                 # nginx + FTP identity; runtime user is in this GROUP
PHP_VERSION=8.1

# Runtime-writable Joomla dirs (relative to DOCROOT, space-separated).
WRITABLE_DIRS="images media cache administrator/cache"

# Churny / out-of-docroot paths (kept off any served path; local disk).
TMP_PATH=/var/www/html/web_user/tmp
SESSION_PATH=/var/www/html/web_user/sessions
LOG_PATH=/var/www/html/web_user/logs

# Egress policy for the runtime user.
DB_HOST=10.0.0.10                 # <-- set to your real DB host/IP
DB_PORT=3306
MAIL_HOST=""                      # <-- set to your SMTP relay IP to allow outbound mail
MAIL_PORTS=25,465,587
ALLOW_HTTPS=yes                   # outbound 443 for Joomla update/extension checks

# session.cookie_secure: keep 'off' on plain-HTTP staging, flip 'on' once TLS is live.
COOKIE_SECURE=off

# Non-interactive automation: auto-create missing user / add to group without prompting.
ASSUME_YES=1

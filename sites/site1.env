# sites/site1.env — answers for vhost "site1" (example: 2 users / 2 docroots).
# Source + run:  sudo bash -c 'set -a; . sites/site1.env; set +a; bash scripts/harden-vhost.sh'
SITE=site1
SERVER_NAME=site1.local
DOCROOT=/var/www/html/site1/public_html
RUNTIME_USER=site1
WEB_USER=www-data
PHP_VERSION=8.1
WRITABLE_DIRS="images media cache administrator/cache"
TMP_PATH=/var/www/html/site1/tmp
SESSION_PATH=/var/www/html/site1/sessions
LOG_PATH=/var/www/html/site1/logs
DB_HOST=127.0.0.1                 # in production: your real DB host/IP
DB_PORT=3306
MAIL_HOST=""
MAIL_PORTS=25,465,587
ALLOW_HTTPS=yes
COOKIE_SECURE=off                 # HTTP staging; flip on with TLS
ASSUME_YES=1                      # non-interactive
ENABLE_APPARMOR_HAT=1             # real host: attach php-fpm//site1

# --- Optional per-site tunables (defaults shown; uncomment to override) ------
#PM_MAX_CHILDREN=10               # concurrent FPM workers (memory/DoS cap)
#PM_MAX_REQUESTS=500              # recycle a worker after N requests
#MEMORY_LIMIT=256M
#UPLOAD_MAX_FILESIZE=32M          # nginx client_max_body_size follows this
#POST_MAX_SIZE=32M
#MAX_EXECUTION_TIME=60

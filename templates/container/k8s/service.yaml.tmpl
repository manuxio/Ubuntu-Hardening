apiVersion: v1
kind: Service
metadata:
  name: @@SITE@@
  namespace: @@NAMESPACE@@
  labels: { app: @@SITE@@ }
spec:
  selector: { app: @@SITE@@ }
  ports:
    - name: http
      port: 80
      targetPort: 8080
  # expose via an Ingress/Gateway of your choice (TLS terminates there); the pod
  # only listens on 8080 and :9000 is pod-internal (see the NetworkPolicy).
